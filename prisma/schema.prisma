// 鑫亚涂装 - 船舶管理系统数据库模型

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ==================== 用户表 ====================
model User {
  id             Int      @id @default(autoincrement())
  username       String   @unique
  password       String
  realName       String   @map("real_name")
  role           String   @default("worker")
  gender         String?
  age            Int?
  craftType      String?  @map("craft_type")
  level          String?
  phone          String?
  teamId         Int?     @map("team_id")
  isActive       Boolean  @default(true) @map("is_active")
  approvalStatus String   @default("approved") @map("approval_status")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  team               Team?                @relation(fields: [teamId], references: [id], onDelete: SetNull)
  ledTeams           Team[]               @relation("TeamLeader")
  externalPlateCosts ExternalPlateCost[]  @relation("Supervisor")
  cargoHoldCosts     CargoHoldCost[]      @relation("CargoSupervisor")
  safetyIssued       SafetyPunishment[]   @relation("Issuer")
  safetyPunished     SafetyPunishment[]   @relation("PunishedPerson")
  workHourRecords    WorkHourRecord[]

  @@map("users")
}

// ==================== 队伍表 ====================
model Team {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  leaderId    Int?     @map("leader_id")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  leader              User?                @relation("TeamLeader", fields: [leaderId], references: [id], onDelete: SetNull)
  members             User[]
  externalPlateCosts  ExternalPlateCost[]
  cargoHoldCosts      CargoHoldCost[]
  rustRemovalCosts    RustRemovalCost[]
  waterJetCosts       WaterJetCost[]
  safetyPunishments   SafetyPunishment[]
  shipTeams           ShipTeam[]
  attendances         Attendance[]
  workHourRecords     WorkHourRecord[]

  @@map("teams")
}

// ==================== 船舶表 ====================
model Ship {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  shipType  String   @map("ship_type")
  length    Float
  width     Float
  height    Float
  status    String   @default("at_sea")
  factoryId Int      @default(1) @map("factory_id")
  dockId    Int?     @map("dock_id")
  berthId   Int?     @map("berth_id")
  positionX Float?   @map("position_x")
  positionZ Float?   @map("position_z")
  rotation       Float?
  repairStatus   String?  @default("not_started") @map("repair_status")
  positionDetail String?  @map("position_detail")
  departureDate  DateTime? @map("departure_date")
  createdAt      DateTime @default(now()) @map("created_at")

  dock               Dock?               @relation("ShipDock", fields: [dockId], references: [id], onDelete: SetNull)
  berth              Dock?               @relation("ShipBerth", fields: [berthId], references: [id], onDelete: SetNull)
  externalPlateCosts ExternalPlateCost[]
  cargoHoldCosts     CargoHoldCost[]
  rustRemovalCosts   RustRemovalCost[]
  waterJetCosts      WaterJetCost[]
  shipTeams          ShipTeam[]
  attendances        Attendance[]
  workHourRecords    WorkHourRecord[]

  @@map("ships")
}

// ==================== 码头/船坞/泊位表 ====================
model Dock {
  id        Int      @id @default(autoincrement())
  name      String
  type      String
  factoryId Int      @default(1) @map("factory_id")
  positionX Float    @map("position_x")
  positionZ Float    @map("position_z")
  width     Float
  depth     Float
  status    String   @default("available")
  createdAt DateTime @default(now()) @map("created_at")

  dockedShips  Ship[] @relation("ShipDock")
  berthedShips Ship[] @relation("ShipBerth")
  attendances  Attendance[]
  gantryCranes GantryCrane[]

  @@map("docks")
}

// ==================== 门座式起重机表 ====================
model GantryCrane {
  id        Int      @id @default(autoincrement())
  name      String
  factoryId Int      @default(1) @map("factory_id")
  dockId    Int?     @map("dock_id")
  positionX Float    @map("position_x")
  positionZ Float    @map("position_z")
  rotation  Float    @default(0)
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")

  dock Dock? @relation(fields: [dockId], references: [id], onDelete: SetNull)

  @@map("gantry_cranes")
}

// ==================== 外板成本表 ====================
model ExternalPlateCost {
  id               Int      @id @default(autoincrement())
  repairNumber     String?  @map("repair_number")
  shipId           Int      @map("ship_id")
  supervisorId     Int      @map("supervisor_id")
  dockEntryTime    DateTime @map("dock_entry_time")
  area             String
  teamId           Int      @map("team_id")
  settlementCost   Float    @map("settlement_cost")
  constructionCost Float    @map("construction_cost")
  remarks          String?
  projectStatus    String?  @default("in_progress") @map("project_status")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  ship       Ship @relation(fields: [shipId], references: [id], onDelete: Restrict)
  supervisor User @relation("Supervisor", fields: [supervisorId], references: [id], onDelete: Restrict)
  team       Team @relation(fields: [teamId], references: [id], onDelete: Restrict)

  @@index([shipId])
  @@index([supervisorId])
  @@index([teamId])
  @@map("external_plate_costs")
}

// ==================== 货舱成本表 ====================
model CargoHoldCost {
  id               Int      @id @default(autoincrement())
  repairNumber     String?  @map("repair_number")
  shipId           Int      @map("ship_id")
  supervisorId     Int      @map("supervisor_id")
  cargoRatio       Float    @map("cargo_ratio")
  originalRatio    Float    @map("original_ratio")
  originalPhoto    String?  @map("original_photo")
  teamId           Int?     @map("team_id")
  settlementCost   Float    @map("settlement_cost")
  constructionCost Float    @map("construction_cost")
  remarks          String?
  projectStatus    String?  @default("in_progress") @map("project_status")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  ship       Ship @relation(fields: [shipId], references: [id], onDelete: Restrict)
  supervisor User @relation("CargoSupervisor", fields: [supervisorId], references: [id], onDelete: Restrict)
  team       Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([shipId])
  @@index([supervisorId])
  @@index([teamId])
  @@map("cargo_hold_costs")
}

// ==================== 敲铲成本表 ====================
model RustRemovalCost {
  id          Int      @id @default(autoincrement())
  repairNumber String? @map("repair_number")
  shipId      Int      @map("ship_id")
  area        String
  projectName String   @map("project_name")
  teamId      Int?     @map("team_id")
  manHours    Float    @map("man_hours")
  hourlyRate  Float    @default(0) @map("hourly_rate")
  remarks     String?
  projectStatus String? @default("in_progress") @map("project_status")
  createdAt   DateTime @default(now()) @map("created_at")

  ship Ship @relation(fields: [shipId], references: [id], onDelete: Restrict)
  team Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([shipId])
  @@index([teamId])
  @@map("rust_removal_costs")
}

// ==================== 安全处罚表 ====================
model SafetyPunishment {
  id               Int      @id @default(autoincrement())
  teamId           Int      @map("team_id")
  punishedPersonId Int?     @map("punished_person_id")
  issuerId         Int      @map("issuer_id")
  punishmentTime   DateTime @map("punishment_time")
  category         String
  amount           Float
  reason           String
  createdAt        DateTime @default(now()) @map("created_at")

  team           Team  @relation(fields: [teamId], references: [id], onDelete: Restrict)
  punishedPerson User? @relation("PunishedPerson", fields: [punishedPersonId], references: [id], onDelete: SetNull)
  issuer         User  @relation("Issuer", fields: [issuerId], references: [id], onDelete: Restrict)

  @@index([teamId])
  @@index([punishmentTime])
  @@index([category])
  @@map("safety_punishments")
}

// ==================== 水刀成本表 ====================
model WaterJetCost {
  id               Int      @id @default(autoincrement())
  repairNumber     String?  @map("repair_number")
  shipId           Int      @map("ship_id")
  dockEntryTime    DateTime @default(now()) @map("dock_entry_time")
  project          String
  teamId           Int      @map("team_id")
  settlementCost   Float    @map("settlement_cost")
  constructionCost Float    @map("construction_cost")
  remarks          String?
  projectStatus    String?  @default("in_progress") @map("project_status")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  ship Ship @relation(fields: [shipId], references: [id], onDelete: Restrict)
  team Team @relation(fields: [teamId], references: [id], onDelete: Restrict)

  @@index([shipId])
  @@index([teamId])
  @@map("water_jet_costs")
}

// ==================== 船舶-施工队关联表 ====================
model ShipTeam {
  id         Int      @id @default(autoincrement())
  shipId     Int      @map("ship_id")
  teamId     Int      @map("team_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  ship Ship @relation(fields: [shipId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([shipId, teamId])
  @@index([shipId])
  @@index([teamId])
  @@map("ship_teams")
}

// ==================== 出勤记录表 ====================
model Attendance {
  id          Int       @id @default(autoincrement())
  teamId      Int       @map("team_id")
  shipId      Int?      @map("ship_id")
  dockId      Int?      @map("dock_id")
  workerCount Int       @map("worker_count")
  startTime   DateTime  @map("start_time")
  endTime     DateTime? @map("end_time")
  createdAt   DateTime  @default(now()) @map("created_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Restrict)
  ship Ship? @relation(fields: [shipId], references: [id], onDelete: SetNull)
  dock Dock? @relation(fields: [dockId], references: [id], onDelete: SetNull)

  @@index([teamId])
  @@index([shipId])
  @@index([dockId])
  @@index([endTime])
  @@map("attendances")
}

// ==================== 3D场景设置表（双厂区，id=1鑫亚，id=2亚泰） ====================
model SceneSettings {
  id                Int     @id @default(autoincrement())
  factoryId         Int     @unique @default(1)
  coastlineZ        Float   @default(0)
  waterOpacity      Float   @default(0.6)
  ambientIntensity  Float   @default(0.6)
  bgColor           String  @default("#0A1628")
  fogNear           Float   @default(60)
  fogFar            Float   @default(200)
  factoryLayout     String?
  gantryCraneCount  Int     @default(4)
  mapCenterX        Float   @default(0)
  mapCenterZ        Float   @default(0)
  updatedAt         DateTime @updatedAt

  @@map("scene_settings")
}

// ==================== 每日工时主记录表 ====================
model WorkHourRecord {
  id         Int      @id @default(autoincrement())
  recordDate DateTime @map("record_date")
  shipId     Int      @map("ship_id")
  teamId     Int      @map("team_id")
  note       String?  @map("note")
  createdBy  Int      @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  ship    Ship @relation(fields: [shipId], references: [id], onDelete: Restrict)
  team    Team @relation(fields: [teamId], references: [id], onDelete: Restrict)
  creator User @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  entries WorkHourEntry[]

  @@unique([recordDate, shipId, teamId])
  @@index([recordDate])
  @@index([shipId])
  @@index([teamId])
  @@index([createdBy])
  @@map("work_hour_records")
}

// ==================== 工种工时明细表 ====================
model WorkHourEntry {
  id               Int     @id @default(autoincrement())
  workHourRecordId Int     @map("work_hour_record_id")
  craftType        String  @map("craft_type")
  workerCount      Int     @map("worker_count")
  workDays         Float   @map("work_days")
  createdAt        DateTime @default(now()) @map("created_at")

  record    WorkHourRecord @relation(fields: [workHourRecordId], references: [id], onDelete: Cascade)
  timeSlots WorkHourTimeSlot[]

  @@index([workHourRecordId])
  @@map("work_hour_entries")
}

// ==================== 工作时间段表 ====================
model WorkHourTimeSlot {
  id              Int      @id @default(autoincrement())
  workHourEntryId Int      @map("work_hour_entry_id")
  startTime       DateTime @map("start_time")
  endTime         DateTime @map("end_time")
  hours           Float    @map("hours")
  createdAt       DateTime @default(now()) @map("created_at")

  entry WorkHourEntry @relation(fields: [workHourEntryId], references: [id], onDelete: Cascade)

  @@index([workHourEntryId])
  @@map("work_hour_time_slots")
}
