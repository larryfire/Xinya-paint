// 心雅涂装 - 船舶管理系统数据库模型

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ==================== 用户表 ====================
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  realName  String   @map("real_name")
  role      String   @default("worker")
  gender    String?
  age       Int?
  craftType String?  @map("craft_type")
  level     String?
  phone     String?
  teamId    Int?     @map("team_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  team               Team?                @relation(fields: [teamId], references: [id], onDelete: SetNull)
  ledTeams           Team[]               @relation("TeamLeader")
  externalPlateCosts ExternalPlateCost[]  @relation("Supervisor")
  cargoHoldCosts     CargoHoldCost[]      @relation("CargoSupervisor")
  safetyIssued       SafetyPunishment[]   @relation("Issuer")
  safetyPunished     SafetyPunishment[]   @relation("PunishedPerson")

  @@map("users")
}

// ==================== 队伍表 ====================
model Team {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  leaderId    Int?     @map("leader_id")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  leader              User?                @relation("TeamLeader", fields: [leaderId], references: [id], onDelete: SetNull)
  members             User[]
  externalPlateCosts  ExternalPlateCost[]
  rustRemovalCosts    RustRemovalCost[]
  safetyPunishments   SafetyPunishment[]
  shipTeams           ShipTeam[]

  @@map("teams")
}

// ==================== 船舶表 ====================
model Ship {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  shipType  String   @map("ship_type")
  length    Float
  width     Float
  height    Float
  status    String   @default("at_sea")
  dockId    Int?     @map("dock_id")
  berthId   Int?     @map("berth_id")
  positionX Float?   @map("position_x")
  positionZ Float?   @map("position_z")
  rotation  Float?
  createdAt DateTime @default(now()) @map("created_at")

  dock               Dock?               @relation("ShipDock", fields: [dockId], references: [id], onDelete: SetNull)
  berth              Dock?               @relation("ShipBerth", fields: [berthId], references: [id], onDelete: SetNull)
  externalPlateCosts ExternalPlateCost[]
  cargoHoldCosts     CargoHoldCost[]
  rustRemovalCosts   RustRemovalCost[]
  shipTeams          ShipTeam[]

  @@map("ships")
}

// ==================== 码头/船坞/泊位表 ====================
model Dock {
  id        Int      @id @default(autoincrement())
  name      String
  type      String
  positionX Float    @map("position_x")
  positionZ Float    @map("position_z")
  width     Float
  depth     Float
  status    String   @default("available")
  createdAt DateTime @default(now()) @map("created_at")

  dockedShips  Ship[] @relation("ShipDock")
  berthedShips Ship[] @relation("ShipBerth")

  @@map("docks")
}

// ==================== 外板成本表 ====================
model ExternalPlateCost {
  id               Int      @id @default(autoincrement())
  shipId           Int      @map("ship_id")
  supervisorId     Int      @map("supervisor_id")
  dockEntryTime    DateTime @map("dock_entry_time")
  area             String
  teamId           Int      @map("team_id")
  settlementCost   Float    @map("settlement_cost")
  constructionCost Float    @map("construction_cost")
  remarks          String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  ship       Ship @relation(fields: [shipId], references: [id], onDelete: Restrict)
  supervisor User @relation("Supervisor", fields: [supervisorId], references: [id], onDelete: Restrict)
  team       Team @relation(fields: [teamId], references: [id], onDelete: Restrict)

  @@index([shipId])
  @@index([supervisorId])
  @@index([teamId])
  @@map("external_plate_costs")
}

// ==================== 货舱成本表 ====================
model CargoHoldCost {
  id               Int      @id @default(autoincrement())
  shipId           Int      @map("ship_id")
  supervisorId     Int      @map("supervisor_id")
  cargoRatio       Float    @map("cargo_ratio")
  originalRatio    Float    @map("original_ratio")
  originalPhoto    String?  @map("original_photo")
  settlementCost   Float    @map("settlement_cost")
  constructionCost Float    @map("construction_cost")
  remarks          String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  ship       Ship @relation(fields: [shipId], references: [id], onDelete: Restrict)
  supervisor User @relation("CargoSupervisor", fields: [supervisorId], references: [id], onDelete: Restrict)

  @@index([shipId])
  @@index([supervisorId])
  @@map("cargo_hold_costs")
}

// ==================== 敲铲成本表 ====================
model RustRemovalCost {
  id          Int      @id @default(autoincrement())
  shipId      Int      @map("ship_id")
  area        String
  projectName String   @map("project_name")
  teamId      Int?     @map("team_id")
  manHours    Float    @map("man_hours")
  hourlyRate  Float    @default(0) @map("hourly_rate")
  remarks     String?
  createdAt   DateTime @default(now()) @map("created_at")

  ship Ship @relation(fields: [shipId], references: [id], onDelete: Restrict)
  team Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([shipId])
  @@index([teamId])
  @@map("rust_removal_costs")
}

// ==================== 安全处罚表 ====================
model SafetyPunishment {
  id               Int      @id @default(autoincrement())
  teamId           Int      @map("team_id")
  punishedPersonId Int?     @map("punished_person_id")
  issuerId         Int      @map("issuer_id")
  punishmentTime   DateTime @map("punishment_time")
  category         String
  amount           Float
  reason           String
  createdAt        DateTime @default(now()) @map("created_at")

  team           Team  @relation(fields: [teamId], references: [id], onDelete: Restrict)
  punishedPerson User? @relation("PunishedPerson", fields: [punishedPersonId], references: [id], onDelete: SetNull)
  issuer         User  @relation("Issuer", fields: [issuerId], references: [id], onDelete: Restrict)

  @@index([teamId])
  @@index([punishmentTime])
  @@index([category])
  @@map("safety_punishments")
}

// ==================== 船舶-施工队关联表 ====================
model ShipTeam {
  id         Int      @id @default(autoincrement())
  shipId     Int      @map("ship_id")
  teamId     Int      @map("team_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  ship Ship @relation(fields: [shipId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([shipId, teamId])
  @@index([shipId])
  @@index([teamId])
  @@map("ship_teams")
}
