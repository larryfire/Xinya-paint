# ============================================
# 开发环境
# ============================================
# 开发时使用 SQLite，复制此文件为 .env
DATABASE_URL="file:./dev.db"
JWT_SECRET="dev-secret-change-in-production"

# Vue 3D 子应用开发服务器地址（开发时启用，生产环境留空使用 /static/vue-3d/index.html）
# NEXT_PUBLIC_VUE_3D_URL="http://localhost:5173"

# ============================================
# 生产环境 (Docker Compose 部署)
# ============================================
# 生产环境请使用 deploy/.env.production 模板
# 复制 deploy/.env.production 到根目录并修改密码后运行:
#   ./deploy/deploy.sh
